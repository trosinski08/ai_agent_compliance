# Qdrant local file mode (default, no Docker required)
QDRANT_PATH=./qdrant_storage
QDRANT_COLLECTION=aml_przepisy

# Uncomment and clear QDRANT_PATH to use a running Qdrant server instead
# QDRANT_PATH=
# QDRANT_URL=http://localhost:6333

# Fast (dev): paraphrase-multilingual-MiniLM-L12-v2 — 384-dim, ~1min/150 chunks
# Quality (prod): sdadas/mmlw-retrieval-roberta-large — 1024-dim, ~20min/150 chunks on CPU
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_BATCH_SIZE=32

OLLAMA_URL=http://localhost:11434
# qwen2.5:3b — 1.9 GB, mieści się w 2.7 GB wolnego RAM
# bielik — lepszy dla PL, ale wymaga ~8 GB RAM
LLM_MODEL=qwen2.5:3b

RETRIEVAL_TOP_K=6
RETRIEVAL_SCORE_THRESHOLD=0.60

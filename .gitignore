# =============================
# Global project .gitignore
# Stack: Python (FastAPI, sentence-transformers), n8n workflows, Docker compose
# Adjust / uncomment sections as needed.
# =============================

###############################
# Python bytecode / build
###############################
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.dll
*.egg-info/
.eggs/
build/
dist/
pip-wheel-metadata/
*.manifest
*.spec

###############################
# Virtual environments
###############################
.venv/
venv/
env/
ENV/
.python-version

###############################
# Tool caches / test artifacts
###############################
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
/.benchmarks/
profiler.out

###############################
# Jupyter / notebooks
###############################
*.ipynb_checkpoints/

###############################
# Editors / IDE
###############################
.vscode/
.idea/
*.swp
*.swo
*.code-workspace

###############################
# OS / misc
###############################
Thumbs.db
Desktop.ini
.DS_Store
ehthumbs.db

###############################
# Logs & runtime outputs
###############################
*.log
logs/
self-hosted-ai-starter-kit/logs/
self-hosted-ai-starter-kit/logs/queries/*.json
api.out
self-hosted-ai-starter-kit/api.out

###############################
# Credentials / sensitive (n8n imported credentials)
###############################
self-hosted-ai-starter-kit/n8n/demo-data/credentials/*.json

# If you want to keep example credential schema, create a placeholder file and whitelist it.
# !self-hosted-ai-starter-kit/n8n/demo-data/credentials/README.keep

###############################
# n8n ephemeral storage (mounted volume path if ever added locally)
###############################
n8n_storage/

###############################
# Model / embedding / vector cache (typical locations if created locally)
###############################
/.cache/
cache/
sentence_transformers/
hf_cache/
model_cache/
.ollama/

###############################
# Qdrant / DB snapshots (volumes live outside repo, ignore any accidental paths)
###############################
qdrant_storage/
*.db
*.sqlite
*.sqlite3

###############################
# Node / frontend (if later added)
###############################
node_modules/
pnpm-lock.yaml
package-lock.json
yarn.lock

###############################
# Environment & compose overrides
###############################
.env
*.env.local
docker-compose.override.yml

###############################
# Temporary / scratch
###############################
tmp/
temp/
*.tmp
*.bak
*.orig
*.rej

###############################
# PDF Knowledge base (OPTIONAL)
# Uncomment following lines if you do NOT want to version source PDFs.
# knowledge_base/*.pdf

###############################
# Generated embeddings / ingestion artifacts (if you later export them)
###############################
embeddings/*.json
embeddings/*.npy

###############################
# Python packaging extras (future)
###############################
MANIFEST
MANIFEST.in

###############################
# Archive files
###############################
*.tar
*.tar.gz
*.zip
*.7z
*.rar

###############################
# End of file
